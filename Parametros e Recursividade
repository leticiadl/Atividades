// 6.Crie um método recursivo que receba um número inteiro e faça a contagem regressiva até zero.
public class Main {
    static void main() {
        Repeticao r = new Repeticao();
        r.regresso(5);
    }
}

public class Repeticao {
    public static void regresso(int num1) {
        if (num1 < 0) {
            return;
        }
        System.out.println(num1);
        regresso(num1 - 1);
    }
}

// 7.Crie um método recursivo que calcule a soma dos números de 1 até n.
public class Main {
    static void main() {
        Repeticao r = new Repeticao();
        int resultado = r.contar(5);
        System.out.println(resultado);
    }
}

public class Repeticao {
    public static int contar(int num1) {
        if (num1 == 0) {
            return 0;
        }
        return num1 + contar(num1-1);
    }
}

// 8.Crie um método recursivo que calcule o fatorial de um número inteiro.
public class Main {
    static void main() {
        Repeticao r = new Repeticao();
        int resultado = r.fatorial(5);
        System.out.println(resultado);
    }
}

public class Repeticao {
    public static int fatorial(int num1) {
        if (num1 == 0) {
            return 1;
        }
        return num1 * fatorial(num1-1);
    }
}

// 9.Crie um método recursivo que imprima os números de 1 até n em ordem crescente.
public class Main {
    static void main() {
        Repeticao r = new Repeticao();
        r.contar(5);
    }
}

public class Repeticao {
    public static void contar(int num1) {
        if (num1 == 0) {
            return;
        }
        contar(num1 - 1);
        System.out.println(num1);
    }
}

// 10.Crie um método recursivo que calcule o enésimo termo da sequência de Fibonacci.
public class Main {
    static void main() {
        Fibonacci r = new Fibonacci();
        int resultado = r.fibonacci(8);
        System.out.println(resultado);
    }
}

public class Fibonacci {
    public static int fibonacci(int num1) {
        if (num1 == 1) {
            return 0;
        } else if (num1 == 2) {
            return 1;
        }
        return fibonacci(num1 - 1) + fibonacci(num1 - 2);
    }
}
