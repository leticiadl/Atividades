/* 1.Crie um programa em Java utilizando um vetor do tipo Object[] para armazenar diferentes
tipos de dados em uma única estrutura. O vetor deve conter um nome (String),
uma idade (Integer), uma altura (Double) e um valor booleano indicando se a pessoa é
estudante. Após preencher o vetor, o programa deve percorrer todos os elementos e
exibir cada valor armazenado na tela. */
public class Main {
    static void main() {
        Object[][] planilha = new Object[2][4];
        planilha[0][0] = "nome";
        planilha[0][1] = "idade";
        planilha[0][2] = "altura";
        planilha[0][3] = "estudante";

        planilha[1][0] = "Lele";
        planilha[1][1] = "19";
        planilha[1][2] = "1,70";
        planilha[1][3] = "true";

        System.out.println(planilha[0][0] +" | "+ planilha[0][1] +" | "+ planilha[0][2] +" | "+ planilha[0][3]);
        System.out.println(planilha[1][0] +" | "+ planilha[1][1] +" | "+ planilha[1][2] +" | "+ planilha[1][3]);
    }
}

/* 2.Crie um programa utilizando um vetor Object[] com valores mistos (String, Integer, Double
e Boolean). Em seguida, percorra o vetor e utilize instanceof para identificar o tipo de
cada elemento. O programa deve exibir uma mensagem informando o tipo de cada valor
armazenado. */
public class Main {
    static void main() {
        Object[][] planilha = new Object[2][4];
        planilha[0][0] = "nome";
        planilha[0][1] = "idade";
        planilha[0][2] = "altura";
        planilha[0][3] = "estudante";

        planilha[1][0] = "Lele";
        planilha[1][1] = 19;
        planilha[1][2] = 1.70;
        planilha[1][3] = true;

        System.out.println(planilha[0][0] + " | " + planilha[0][1] + " | " + planilha[0][2] + " | " + planilha[0][3]);
        System.out.println(planilha[1][0] + " | " + planilha[1][1] + " | " + planilha[1][2] + " | " + planilha[1][3]);

        for (int i = 0; i < planilha.length; i++) {
            for (int j = 0; j < planilha[0].length; j++) {
                if (planilha[i][j] instanceof String) {
                    System.out.println(planilha[i][j] + " é String");
                } else if (planilha[i][j] instanceof Integer) {
                    System.out.println(planilha[i][j] + " é Inteiro");
                } else if (planilha[i][j] instanceof Double) {
                    System.out.println(planilha[i][j] + " Éé double");
                } else if (planilha[i][j] instanceof Boolean) {
                    System.out.println(planilha[i][j] + " é Boolean");
                }

            }
        }
    }
}

