/* 5.Crie um programa utilizando um vetor do tipo Object[] para simular uma nota de compra.
O vetor deve armazenar produtos contendo nome, quantidade e valor unitário. O
programa deve percorrer o vetor, calcular o valor total de cada produto (quantidade ×
valor unitário) e somar todos os valores para obter o total final da compra. Ao final, o
programa deve exibir o valor total da nota. */
public class Main {
    static void main() {
        Object[][] planilha = new Object[3][3];
        planilha[0][0] = "Nome";
        planilha[0][1] = "Quantidade";
        planilha[0][2] = "Preço";

        planilha[1][0] = "Agulha";
        planilha[1][1] = 15;
        planilha[1][2] = 3.90;

        planilha[2][0] = "Linha";
        planilha[2][1] = 30;
        planilha[2][2] = 5.0;

        System.out.println(planilha[0][0] + " | " + planilha[0][1] + " | " + planilha[0][2]);
        System.out.println(planilha[1][0] + " | " + planilha[1][1] + " | " + planilha[1][2]);
        System.out.println(planilha[2][0] + " | " + planilha[2][1] + " | " + planilha[2][2]);

        double totalCompra = 0;
        for (int i = 1; i < planilha.length; i++) {
            int quantidade = (Integer) planilha[i][1];
            double preco = (Double) planilha[i][2];
            double totalProduto = quantidade * preco;
            System.out.println("Total de " + planilha[i][0] + ": " + totalProduto);
            totalCompra += totalProduto;
        }
        IO.println("Valor total da compra é: " + totalCompra);
    }
}
